{
  "name": "@academic360/db",
  "version": "1.0.0",
  "description": "Database schemas, models, DTOs, and types for Academic360",
  "type": "module",
  "imports": {
    "#db/*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsc --watch --preserveWatchOutput",
    "lint": "eslint src --ext .ts",
    "prettier": "@academic360/prettier-config",
    "db:generate": "pnpm dlx drizzle-kit generate",
    "db:migrate": "pnpm dlx drizzle-kit migrate",
    "db:push": "pnpm dlx drizzle-kit push",
    "db:studio": "pnpm dlx drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "pg": "^8.16.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@academic360/typescript-config": "workspace:*",
    "@academic360/eslint-config": "workspace:*",
    "@academic360/prettier-config": "workspace:*",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
