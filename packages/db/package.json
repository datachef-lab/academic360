{
  "name": "@academic360/db",
  "version": "1.0.0",
  "description": "Database schemas, models, DTOs, and types for Academic360",
  "type": "module",
  "private": true,
  "prettier": "@academic360/prettier-config",
  "imports": {
    "#db/*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsc --watch --preserveWatchOutput",
    "lint": "eslint .",
    "db:generate": "tsx --tsconfig tsconfig.json ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --tsconfig tsconfig.json ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "tsx --tsconfig tsconfig.json ./node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "tsx --tsconfig tsconfig.json ./node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "catalog:",
    "pg": "^8.16.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@academic360/eslint-config": "workspace:*",
    "@academic360/prettier-config": "workspace:*",
    "@academic360/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.10",
    "dotenv": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "tsc-alias": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
