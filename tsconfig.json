{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2023", "dom"],
    "baseUrl": ".",
    "paths": {
      "@repo/db/*": ["./packages/db/src/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": ["packages/**/*"],
  "exclude": ["node_modules", "dist", "**/dist/**", "apps/**"]
}
