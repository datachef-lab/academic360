{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NEXT_PUBLIC_APP_ENV",
    "NODE_ENV",
    "DEVELOPER_EMAIL",
    "DEVELOPER_PHONE",

    "DATABASE_URL",

    "DB_HOST",
    "DB_PORT",
    "DB_USER",
    "DB_NAME",
    "DB_PASSWORD",

    "DOCS_PATH",

    "JWT_SECRET",
    "JWT_REFRESH_SECRET",

    "COURSE_MATERIAL_PATH",

    "INTERAKT_API_KEY",
    "INTERAKT_BASE_URL",

    "ZEPTO_URL",
    "ZEPTO_FROM",
    "ZEPTO_TOKEN",

    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "docker:build": {
      "dependsOn": ["build"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
