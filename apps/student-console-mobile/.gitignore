# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# The native folders are committed, so this is a bare project: EAS Build uses
# them as-is and never runs prebuild. They must NOT be ignored — EAS classifies
# the workflow from the local filesystem but uploads by these rules, so ignoring
# them ships a build with no android/gradlew. Each folder has its own .gitignore
# for real build output (build/, .gradle, Pods, local.properties).
# Changing app.json icons/config requires `npx expo prebuild` to take effect.
