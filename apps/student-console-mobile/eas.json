{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "node": "20.19.4",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EAS_ENABLE_COREPACK": "1",
        "EAS_NO_FROZEN_LOCKFILE": "1"
      }
    },
    "stage": {
      "distribution": "internal",
      "channel": "stage",
      "environment": "preview",
      "node": "20.19.4",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EAS_ENABLE_COREPACK": "1",
        "EAS_NO_FROZEN_LOCKFILE": "1"
      }
    }
  }
}
