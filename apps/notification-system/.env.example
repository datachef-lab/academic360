# NODE_ENV = development | staging | production
NODE_ENV=

NOTIFICATION_SYSTEM_PORT=

# Set to "false" to disable email/WhatsApp dispatch on this instance (HTTP/API
# still served). Defaults to enabled when unset. Dispatch is concurrency-safe
# across instances (queue-claim.ts uses FOR UPDATE SKIP LOCKED).
NOTIFICATION_WORKER_ENABLED=true

DEVELOPER_EMAIL=
DEVELOPER_PHONE=

DATABASE_URL=

ZEPTO_URL=
ZEPTO_FROM=
ZEPTO_TOKEN=

INTERAKT_API_KEY=
INTERAKT_BASE_URL=

# Optional when using an EC2/ECS IAM role. Set both only for static keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ROOT_FOLDER=