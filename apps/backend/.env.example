# NODE_ENV= production | development
NODE_ENV=
PORT=8080

DEVELOPER_EMAIL=
DEVELOPER_PHONE=

DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database_name>

OLD_DB_HOST=
OLD_DB_PORT=
OLD_DB_USER=
OLD_DB_NAME=
OLD_DB_PASSWORD=

# Public-facing origin for links in emails (e.g. fee receipt PDFs).
# Precedence: API_PUBLIC_ORIGIN > BACKEND_PUBLIC_URL > BACKEND_URL > localhost
API_PUBLIC_ORIGIN=
BACKEND_PUBLIC_URL=

CORS_ORIGIN=http://localhost:5173

# Required for multi-instance deploys (Socket.IO adapter + shared sessions + password-reset tokens).
# Example: redis://localhost:6379 or redis://:password@redis-host:6379/0
REDIS_URL=
REDIS_SESSION_PREFIX=sess:
SESSION_SECRET=

ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=1h

REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=1d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DOCUMENT_BASE_PATH=
STUDY_MATERIAL_BASE_PATH=

INTERAKT_API_KEY=
INTERAKT_BASE_URL=

ZEPTO_URL=
ZEPTO_FROM=
ZEPTO_TOKEN=

SETTINGS_PATH=

# Optional when using an EC2/ECS IAM role (instance profile). Set both only for static keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
PUPPETEER_EXECUTABLE_PATH=

# Legacy local paths (fallback reads only; new uploads go to S3)
EXAM_FORM_UPLOAD_PATH=

# Paytm Payment Gateway (https://dashboard.paytm.com/next/apikeys)
PAYTM_MID=
PAYTM_MERCHANT_KEY=
PAYTM_WEBSITE=
PAYTM_CALLBACK_URL=
PAYTM_ENVIRONMENT=STAGING
PAYTM_HOST=

# PAYTM_CLIENT_ID=  # Optional; MID is used as fallback if not set
PAYTM_SETTLEMENT_CLIENT_SECRET=
PAYTM_SETTLEMENT_CLIENT_ID=
PAYTM_SETTLEMENT_JWT_EMAIL=
PAYTM_DOWNTIME_CRON_ENABLED=true

APP_MODULE_IMAGE_BASE_PATH=

# Directory for per-table library IRP migration logs (Excel); used by old-irp-data loadLibrary.
LIBRARY_EXCEL_DATA_PATH=

# Backend reaches the notification-system two ways: the /internal/notifications/* proxy
# (app.ts) AND the enqueue client (services/notificationClient.ts, used by OTP, fee
# receipts, promotions, exams, etc.). Both use NOTIFICATION_SYSTEM_URL. In Docker/compose
# this MUST be the service name, NOT localhost (localhost would hit the backend's own
# container -> ECONNREFUSED). Falls back to http://localhost:<NOTIFICATION_SYSTEM_PORT>.
NOTIFICATION_SYSTEM_PORT=5010
NOTIFICATION_SYSTEM_URL=http://notification-worker:5010
# Legacy fallback read only by notificationClient.ts; superseded by NOTIFICATION_SYSTEM_URL.
BACKEND_SELF_BASE=http://notification-worker:5010
# --- Concurrent legacy-student import (Excel UID upload) ---
# Parallel UID workers per process (code default 20; measured 2.4s/uid vs
# 41.6s sequential). Set 1 to restore strictly-sequential imports.
IMPORT_CONCURRENCY=20
# Postgres pool cap (code default 50): each import worker briefly holds up to
# 2 connections during advisory-lock sections, plus normal request traffic.
PG_POOL_MAX=50
# Legacy MySQL pool (code default 30): ~1 in-flight query per import worker
# plus headroom for other legacy readers.
OLD_DB_POOL_LIMIT=30
