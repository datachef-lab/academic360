<!DOCTYPE html
  PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml" xml:lang="en" lang="en">

<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
  <title><%= pageTitle %></title>
  <style type="text/css">
    * {
      margin: 0;
      padding: 0;
      text-indent: 0;
      box-sizing: border-box;

    }

    html,
    body {
      font-family: Arial, sans-serif;
      font-size: 10pt;
      color: black;
      width: 100%;
      padding: 0 10px;
      height: 100vh;
    }

    .copies-container {
      display: flex;
      align-items: stretch;
      min-height: 100vh;
      /* keep overall content narrower than full A4 to avoid printer clipping */
      max-width: 277mm;
      margin: 0 auto;
    }

    .challan-copy {
      border: none;
      border-right: 1px dotted #000;
      padding: 12px;
      flex: 1;
      min-width: 88mm;
      display: flex;
      flex-direction: column;
    }

    .challan-copy:last-child {
      border-right: none;
    }

    .challan-header {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      margin-bottom: 6px;

      /* border-bottom: 1px solid #000; */
    }

    .college-logo {
      width: 65px;
      height: 65px;
      border-radius: 50%;
      object-fit: cover;
      ;

      flex-shrink: 0;
    }

    .header-text {
      flex: 1;
      gap: 2px;
      display: flex;
      flex-direction: column;
    }

    .college-name {
      font-size: 12px;
      text-align: center;
      font-weight: bold;
      margin-bottom: 2px;
    }

    .address {
      font-size: 10px;
      text-align: center;
      margin-bottom: 1px;
      font-weight: bold;
    }

    .session {
      font-size: 10px;
      text-align: center;
      font-weight: bold;
    }

    .bank-details {
      font-size: 10px;
    }

    .bank-staff-note {
      margin: 4px 0;
      margin-bottom: 9px;
      font-size: 7pt;
      text-align: center;
      white-space: normal;
      word-spacing: normal;
      line-height: 1.2;
    }

    .student-info-wrapper {
      display: flex;
      gap: 16px;
      margin-bottom: 8px;
      align-items: flex-end;
    }

    .student-info {
      flex: 1;
      min-width: 0;
    }

    /* Table: first column auto-sizes to longest label; right-aligned labels = tight gap before ":"; colons + values align */
    .student-info-table {
      width: 100%;
      border-collapse: collapse;
      border-spacing: 0;
      table-layout: auto;
    }

    .student-info-table td {
      padding: 2px 0;
      font-size: 10px;
      line-height: 14px;
      vertical-align: top;
    }

    .student-info-table .si-label {
      font-weight: bold;
      text-align: left;
      white-space: nowrap;
      padding-right: 3px;
      vertical-align: top;
    }

    .student-info-table .si-colon {
      font-weight: bold;
      white-space: nowrap;
      padding-left: 0;
      padding-right: 8px;
      vertical-align: top;
    }

    .student-info-table .si-value {
      white-space: nowrap;
      text-align: left;
      vertical-align: top;
    }

    .challan-barcode-block {
      flex-shrink: 0;
      min-width: 130px;
      width: 160px;
      min-height: 50px;
      margin-bottom: 24px;
      margin-right: 4px;
      padding-bottom: 10px;
      white-space: nowrap;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start; /* left-align label + bars */
      text-align: left;
    }

    .challan-no-value {
      display: block;
      font-size: 9pt;
      font-weight: bold;
      margin-bottom: 1px;
      padding-left: 0;
      flex-shrink: 0;
      width: 100%;
      text-align: left;
      line-height: 1.05;
      box-sizing: border-box;
    }

    .challan-barcode-wrap {
      flex-shrink: 0;
      min-height: 40px;
      display: flex;
      align-items: center;
      justify-content: flex-start; /* bars start directly under label */
      width: 100%;
    }

    .challan-barcode {
      display: block;
      width: 160px;
      height: 40px;
      margin: 0;
      flex-shrink: 0;
      padding: 4px 0 0 0px;
    }

    .fee-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 6px;
      font-size: 9pt;
    }

    .fee-table td {
      border: 1px solid #000;
      padding: 4px 6px;
    }

    .fee-table .label {
      font-weight: bold;
    }

    .fee-table .amount {
      text-align: right;
    }

    .total-row {
      font-weight: bold;
      border-top: 2px solid #000 !important;
      border-bottom: 2px solid #000 !important;
    }

    .total-row td {
      border-top: 2px solid #000 !important;
      border-bottom: 2px solid #000 !important;
    }

    .amount-words {
      font-size: 8pt;

      font-style: italic;
      text-align: center;
    }

    .fee-update-note {
      font-size: 9pt;
      /* use full width and distribute spaces */
      text-align: justify;
      text-justify: inter-word;
    }

    .fee-update-note a {
      color: #000;
      text-decoration: underline;
    }

    .nb-notes {
      font-size: 7pt;
    }

    .nb-notes p {
      /* justify NB paragraphs between margins */
      text-align: justify;
      text-justify: inter-word;
    }

    .footer-content {
      margin-top: auto;
    }

    .signature-row {
      margin-top: 12px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      font-size: 9.5pt;
    }

    .signature-row .sig-right {
      white-space: nowrap;
    }

    .signature-line {
      border-bottom: 1px solid #000;
      min-width: 100px;
      display: inline-block;
      margin-left: 6px;
      vertical-align: middle;
    }

    .copy-label {
      font-weight: bold;
      /* slightly smaller so labels don't force extra width/height */
      font-size: 7.5pt;
      margin-top: 12px;
      padding-top: 8px;
      text-align: center;
      letter-spacing: 0px;
    }

    @page {
      /* explicit A4 landscape */
      size: A4 landscape;
      /* use small but safe printer margins */
      margin: 3mm 3mm;
      padding: 0;
    }

    .print-tip {
      padding: 8px 12px;
      background: #fef3c7;
      border: 1px solid #f59e0b;
      font-size: 12px;
      margin-bottom: 12px;
    }

    @media print {

      html,
      body {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        /* let @page control printable area; don't force full-bleed 297mm */
        width: auto !important;
        height: auto !important;
        min-height: 0 !important;
        margin: 0 !important;
        padding: 0 !important;
        overflow: hidden;
      }

      .copies-container {
        /* keep content safely inside @page margins, but stretch close to full width */
        gap: 0 !important;
        max-width: 285mm !important;
        width: 100% !important;
        margin: 0 auto !important;
        page-break-inside: avoid;
      }

      .challan-copy {
        page-break-inside: avoid;
      }

      .challan-copy {
        padding: 24px 12px !important;
      }

      .print-tip {
        display: none !important;
      }
    }
  </style>
</head>

<body>
  <div class="copies-container">
    <% const SECTIONS=["STUDENT COPY", "COLLEGE COPY" , "BANK COPY" ]; %>

      <% SECTIONS.forEach((section, sectionIndex)=> { %>
        <div class="challan-copy">
          <div class="challan-header">
            <img class="college-logo" src="https://besc.academic360.app/api/api/v1/settings/file/4"
              alt="College Logo" />
            <div class="header-text">
              <div class="college-name">The Bhawanipur Education Society College</div>
              <div class="address">5, Lala Lajpat Rai Sarani, Kolkata - 700020</div>
              <div class="session">Session : <%= session %>
              </div>
            </div>
          </div>
          <div class="bank-details">
            <p style="margin-bottom: 1px;">Federal Bank A/c 13040200023571</p>
            <div style="display: flex; justify-content: space-between; width: 100%;">
              <p style="width: 50%; font-size: 9px;">Payment can be made in any branch.</p>
              <p style="font-weight: bold; width: 50%; text-align: right; font-size: 9px;">Preferred branch -
                Bhowanipore
              </p>
            </div>
          </div>
          <div class="bank-staff-note">BANK STAFF: PLEASE ENTER CHALLAN NO IN PARTICULARS /STATEMENT</div>
          <div class="student-info-wrapper">
            <div class="student-info">
              <table class="student-info-table">
                <tr>
                  <td class="si-label">Name</td>
                  <td class="si-colon">:</td>
                  <td class="si-value"><%= name %></td>
                </tr>
                <tr>
                  <td class="si-label">UID</td>
                  <td class="si-colon">:</td>
                  <td class="si-value"><%= uid %></td>
                </tr>
                <tr>
                  <td class="si-label">DOB</td>
                  <td class="si-colon">:</td>
                  <td class="si-value"><%= dob %></td>
                </tr>
                <tr>
                  <td class="si-label">Mob No.</td>
                  <td class="si-colon">:</td>
                  <td class="si-value"><%= phone %></td>
                </tr>
                <tr>
                  <td class="si-label">Year</td>
                  <td class="si-colon">:</td>
                  <td class="si-value"><%= semester %></td>
                </tr>
                <tr>
                  <td class="si-label">Course</td>
                  <td class="si-colon">:</td>
                  <td class="si-value"><%= programCourse %> (<%= shift %>)</td>
                </tr>
              </table>
            </div>
            <div class="challan-barcode-block">
              <span class="challan-no-value">Challan No : <%= challanNumber %></span>
              <div class="challan-barcode-wrap">
                <canvas class="challan-barcode" data-challan="<%= challanNumber %>"></canvas>
              </div>
            </div>
          </div>
          <table class="fee-table">
            <tr>
              <td class="label">Particulars</td>
              <td class="label amount">Amount (in Rs.)</td>
            </tr>
            <% feeComponents.forEach((fc, fcIndex)=> { %>
              <tr>
                <td style="font-size: 9pt;">
                  <%= fc.name %>
                </td>
                <td class="amount">
                  <%= fc.amount %>
                </td>
              </tr>
              <% }) %>
                <tr class="total-row">
                  <td>Total Amount To Pay</td>
                  <td class="amount">
                    <%= totalPayableAmount %>
                  </td>
                </tr>
                <tr class="total-row">
                  <td colspan="2" style="font-style: italic; font-size: 9.5px; font-weight: normal; text-align: end;">
                    (Rs. <%= totalPayableAmountInWords %>)

                  </td>
                </tr>
          </table>
          <div class="amount-words"></div>
          <div class="fee-update-note">If paid in cash at Federal Bank, scan &amp; mail your Fees Paid Challan at <a
              href="mailto:feeupdate@thebges.edu.in" style="font-weight: bold;">feeupdate@thebges.edu.in</a></div>
          <% if (ePaid && ePaid.orderId && ePaid.transactionDate) { %>
            <!-- Center ePAID box within remaining vertical space -->
            <div style="flex: 1; display: flex; align-items: center; justify-content: center;">
              <div style="border: 2px solid #000; border-radius: 10px; padding: 8px 12px; font-size: 10px; font-weight: bold; text-align: center; min-width: 220px;">
                ePAID - <%= ePaid.orderId %><br />
                (<%= ePaid.transactionDate %>)<br />
                <span style="font-weight: normal;">E-paid challan do not<br />require bank stamp</span>
              </div>
            </div>
          <% } else { %>
            <div style="flex: 1; min-height: 8px;"></div>
          <% } %>
          <div class="footer-content">
            <div class="signature-row" style="border-bottom: 1px solid black;">
              <span style="font-weight: bolder;">Date: <span style="font-weight: normal;margin-left: 10px;"><%= challanDate %></span></span>
              <span style="font-weight:bolder;" class="sig-right">Bank Official's Signature</span>
            </div>
            <div class="nb-notes">
              <p>N.B. 1. This receipt is not valid without the seal of the bank, date and signature of the
                receiving
                authority. Please retain the Money Receipt for future reference.</p>
              <p style="margin-bottom:5px;">N.B. 2. Please note that taking enrollment &amp; paying fees for the same
                alone does not make you
                automatically eligible for Calcutta University Exam. Calcutta University Exam Form fill up is
                mandatory
                for each University Exam.</p>
              <p style="margin-bottom: 10px; font-weight: bold;">N.B.3. Please do not make any request to Management
                or
                Staff for refund of fees. Fees once paid is not
                refundable under any circumstances.</p>
            </div>
            <div class="copy-label" style="text-align: end; font-style: italic;">
              <%= section %>
            </div>
          </div>
        </div>
        <% }) %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {

  function sanitizeChallanForBarcode(str) {
    if (!str) return "";
    var s = String(str).trim();
    s = s.replace(/[\x00-\x1F\x7F]/g, "");
    return s;
  }

  var barcodeEls = document.querySelectorAll(".challan-barcode");

  barcodeEls.forEach(function (el) {
    var raw = el.getAttribute("data-challan") || "";
    var value = sanitizeChallanForBarcode(raw);

    if (!value) {
      var wrap = el.closest(".challan-barcode-block");
      if (wrap) {
        var label = wrap.querySelector(".challan-no-value");
        if (label) {
          var text = label.textContent || "";
          if (text.includes(":")) {
            text = text.split(":")[1];
          }
          value = sanitizeChallanForBarcode(text);
        }
      }
    }

    if (!value) return;

    JsBarcode(el, value, {
      format: "CODE128",
      lineColor: "#000",
      width: 2,
      height: 40,
      displayValue: false,
      margin: 0
    });
  });

});
</script>
</body>

</html>