# Copy to repository root as `.env` for `docker compose` variable substitution.
# Compose auto-loads root `.env` for ${VAR} in docker-compose.yml (build args + ports).
# Runtime secrets still come from each app's env_file (see docker-compose.yml).
#
#   cp docker/compose.env.example .env
#   # Edit .env, then: docker compose build && docker compose up -d

# --- Published host ports (browser / curl) ---
BACKEND_PORT=8080
MAIN_CONSOLE_PORT=5173
STUDENT_CONSOLE_PORT=3008
NOTIFICATION_SYSTEM_PORT=8091

# --- main-console (Vite — baked in at IMAGE BUILD, must be URLs the browser can reach) ---
VITE_APP_BACKEND_URL=http://localhost:8080
VITE_APP_STUDENT_CONSOLE_URL=http://localhost:3008
VITE_STUDENT_PROFILE_URL=
VITE_STUDENT_IMAGE_BASE_URL=https://besc.academic360.app/id-card-generate/api/images?crop=true&uid=
VITE_APP_PREFIX=

# --- student-console (Next.js — NEXT_PUBLIC_* baked in at IMAGE BUILD) ---
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_URL=http://localhost:3008

# --- With `docker compose --profile notifications up`, set in apps/backend/.env: ---
# NOTIFICATION_SYSTEM_URL=http://notification-system:8091
# NOTIFICATION_SYSTEM_PORT=8091

# --- Optional: override DB host when using compose `postgres` profile ---
# POSTGRES_USER=academic360
# POSTGRES_PASSWORD=academic360
# POSTGRES_DB=academic360
# DATABASE_URL=postgresql://academic360:academic360@postgres:5432/academic360
